@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> stringLocalizer

@{
    ViewBag.Title = stringLocalizer["Access Denied"];
    Layout = "~/Views/Shared/_UtilityPageLayout.cshtml";
}

@section title {
    <title>@stringLocalizer["Access Denied"]</title>
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <h1 class="display-4">🔒 @stringLocalizer["Access Denied"]</h1>
            <p class="lead mt-4">@stringLocalizer["You do not have permission to access this content."]</p>
            <p class="text-muted">@stringLocalizer["If you believe you should have access, please contact support."]</p>
            <a href="/" class="btn btn-primary mt-4">@stringLocalizer["Return to home"]</a>
        </div>
    </div>
</div>
